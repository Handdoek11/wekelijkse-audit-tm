# === Supabase ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=                    # Service role key (NOT the anon key) — used for writes
SUPABASE_ANON_KEY=                       # Anon key — embedded in the dashboard (public, read-only)

# === Google (shared service account for GA4 + Play) ===
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# === GA4 ===
GA4_PROPERTY_ID=                         # Numeric property ID from GA4 Admin

# === Google Play ===
PLAY_GCS_BUCKET=                         # From Play Console > Download reports > Copy Cloud Storage URI
PLAY_PACKAGE_NAME=                       # e.g., nl.securyflex.talkmark

# === App Store Connect ===
ASC_ISSUER_ID=                           # UUID from App Store Connect > Keys
ASC_KEY_ID=                              # 10-character key ID
ASC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
ASC_VENDOR_NUMBER=                       # From App Store Connect > Sales and Trends
ASC_APP_ID=                              # Numeric Apple App ID

# === Optional ===
LOG_LEVEL=info                           # debug | info | warn | error
DRY_RUN=false                            # Set to 'true' to skip Supabase insert
